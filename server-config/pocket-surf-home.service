[Unit]
Description=Pocket Surf Home Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/etc/pocket-surf
ExecStart=/usr/local/bin/pocket-surf-home
Environment=RUST_LOG=info
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
